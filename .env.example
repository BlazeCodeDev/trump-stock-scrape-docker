# Optional — everything can also be configured in the web UI at http://localhost:1122
# Copy to .env to pre-seed settings on first boot:  cp .env.example .env

# Pre-selected model in the UI. NOTHING is downloaded automatically — open the
# model picker in Settings and click Download. Until a model is downloaded the
# monitor idles (it won't consume posts).
# Good lightweight picks: llama3.2:3b, qwen2.5:3b. Heavier/better: qwen2.5:7b.
MODEL_NAME=llama3.2:3b

# ntfy topic URL — pick a hard-to-guess topic; anyone who knows it can subscribe.
NTFY_URL=https://ntfy.sh/trump-stock-your-random-suffix
